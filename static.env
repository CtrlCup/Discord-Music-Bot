# Zentrale Versionsübersicht (wird über Git versioniert, siehe update_helper.py):
# - BOT_VERSION: Version des Bots selbst (wird in !info/!version angezeigt und gegen GitHub geprüft)
# - ENV_TEMPLATE_VERSION: Version des .env.example-Schemas (muss zu dessen "# Version:"-Kopfzeile passen)
# - COMPOSE_TEMPLATE_VERSION: Version des docker-compose.yml.example-Schemas (muss zu dessen "# Version:"-Kopfzeile passen)
BOT_VERSION=0.1.5
ENV_TEMPLATE_VERSION=1.0.1
COMPOSE_TEMPLATE_VERSION=1.0.0

# Statische Bot-Informationen (wird über Git versioniert)
BOT_DESCRIPTION=
BOT_SUPPORT_SERVER=https://discord.gg/2cEdzd5MW
BOT_GITHUB=https://github.com/CtrlCup/Discord-Music-Bot
