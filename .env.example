# Version: 1.0.0
# Discord Bot (Developer Portal -> Bot -> Reset Token)
DISCORD_BOT_TOKEN=

# Discord OAuth2 (Developer Portal -> OAuth2). Client ID = Application ID.
DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=
# Muss exakt mit einer hinterlegten Redirect-URI im Developer Portal übereinstimmen
DISCORD_OAUTH_REDIRECT_URI=https://CHANGE-ME.example.com/oauth/callback
# Scopes für !connect (kommagetrennt)
OAUTH_SCOPES=identify,email
# Port, auf dem der interne OAuth-Callback-Webserver lauscht (siehe docker-compose.yml)
OAUTH_WEB_PORT=8080

# Spotify (developer.spotify.com/dashboard, Client-Credentials-Flow)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Datenbank: sqlite oder mysql
DB_TYPE=sqlite
SQLITE_PATH=/app/data/bot_database.db

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=bot
MYSQL_PASSWORD=changeme
MYSQL_DATABASE=discord_bot_stats
# Nur für den mysql-Container selbst (docker-compose.yml, profile "mysql") relevant
MYSQL_ROOT_PASSWORD=changeme

# Bot-Grundeinstellungen
BOT_DISPLAY_NAME=🎵 MusicMaster Bot
BOT_PREFIX=!,/
BOT_ACTIVITY=Hört auf /info

# Optional: Server-ID für sofortigen Slash-Command-Sync während der Entwicklung
# (globaler Sync ohne diese Einstellung kann bis zu 1 Stunde dauern, bis er überall sichtbar ist)
DEV_GUILD_ID=

# Musik/Radio
MUSIC_TIMEOUT=300
MUSIC_EMPTY_CHANNEL_TIMEOUT=120
MUSIC_DEFAULT_STREAM_URL=https://ilovemusic.de/iloveradio.m3u
# JSON-Liste weiterer Sender, per !radio play <name> abspielbar
RADIO_STREAMS=[{"name": "iloveradio", "title": "I Love Radio", "url": "https://ilovemusic.de/iloveradio.m3u"}]

# Playlists
PLAYLISTS_MAX_PER_USER=10

# Songwechsel-Ankündigungen (Standard, pro Server per !settings änderbar)
NOTIFICATIONS_SONG_CHANGE_DEFAULT_ENABLED=true
